{
  "name": "@effect-app/cli",
  "version": "2.1.0-beta.14",
  "license": "MIT",
  "type": "module",
  "bin": {
    "effect-app": "./bin.js",
    "effa": "./bin.js",
    "effect-app-cli": "./bin.js"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.52",
    "effect": "^4.0.0-beta.52",
    "js-yaml": "4.1.1",
    "node-watch": "^0.7.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.5.2",
    "json5": "^2.2.3",
    "typescript": "~6.0.2",
    "vitest": "^4.1.3",
    "effect-app": "workspace:*",
    "@effect-app/eslint-shared-config": "workspace:*"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./argv-patch": {
      "types": "./dist/argv-patch.d.ts",
      "default": "./dist/argv-patch.js"
    },
    "./extract": {
      "types": "./dist/extract.d.ts",
      "default": "./dist/extract.js"
    },
    "./gist": {
      "types": "./dist/gist.d.ts",
      "default": "./dist/gist.js"
    },
    "./os-command": {
      "types": "./dist/os-command.d.ts",
      "default": "./dist/os-command.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "default": "./dist/shared.js"
    },
    "./sync-effect-subtree": {
      "types": "./dist/sync-effect-subtree.d.ts",
      "default": "./dist/sync-effect-subtree.js"
    }
  },
  "scripts": {
    "watch": "pnpm build:tsc -w",
    "build:tsc": "pnpm clean-dist && pnpm check",
    "check": "tsc --build",
    "build": "pnpm build:tsc",
    "watch2": "pnpm clean-dist && NODE_OPTIONS=--max-old-space-size=6144 tsc -w",
    "clean": "rm -rf dist",
    "clean-dist": "sh ../../scripts/clean-dist.sh",
    "circular": "pnpm circular:src && pnpm circular:dist",
    "circular:src": "madge --circular --ts-config ./tsconfig.json --extensions ts ./src",
    "circular:dist": "madge --circular --extensions js ./dist",
    "compile": "NODE_OPTIONS=--max-old-space-size=6144 tsc --noEmit",
    "lint": "NODE_OPTIONS=--max-old-space-size=6144 ESLINT_TS=1 eslint ./src",
    "lint:watch": "ESLINT_TS=1 esw -w --changed --clear --ext ts,tsx .",
    "lint-fix": "pnpm lint --fix",
    "test": "vitest",
    "test:run": "pnpm run test run --passWithNoTests",
    "testsuite": "pnpm lint && pnpm circular && pnpm run test:run",
    "ncu": "ncu",
    "pub": "pnpm prepublish && npm publish --access public",
    "prepublish": "cp -f ./tsconfig.json ./tsconfig.json.bak && node ../../scripts/mergeTsConfig.mjs ./tsconfig.json",
    "postpublish": "mv -f ./tsconfig.json.bak ./tsconfig.json && rm -f tsplus.config.json"
  },
  "gitHead": "bd8e27eea3eff97db8739d577d67e7336c078d28",
  "sideEffects": [
    "./dist/faker.js",
    "./faker",
    "./src/faker",
    "./dist/faker",
    "./dist/src/faker.js",
    "./dist/faker.js"
  ]
}