{
  "name": "@effect-app/eslint-shared-config",
  "version": "0.6.0-beta.26",
  "description": "Shared flat ESLint base & vue configs for effect-app monorepo",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "watch": "pnpm build -w",
    "build": "echo 'Nothing to build (config only)'",
    "pub": "pnpm prepublish && npm publish --access public",
    "prepublish": "echo 'No build step for config package'",
    "postpublish": "echo 'Published @effect-app/eslint-shared-config'",
    "prepack": "echo 'ready'"
  },
  "exports": {
    "./eslint.base.config": {
      "default": "./src/eslint.base.config.mjs"
    },
    "./eslint.vue.config": {
      "default": "./src/eslint.vue.config.mjs"
    },
    "./oxlintrc.json": "./src/oxlintrc.json",
    "./dprint.jsonc": "./src/dprint.jsonc"
  },
  "dependencies": {
    "@effect-app/eslint-codegen-model": "workspace:*",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "@eslint/js": "10.0.1",
    "@eslint/eslintrc": "3.3.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-sort-destructure-keys": "3.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "eslint-plugin-formatjs": "6.4.8",
    "eslint-plugin-vue": "10.9.1",
    "vue-eslint-parser": "10.4.0",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "globals": "17.6.0",
    "dprint-plugin-malva": "0.15.3",
    "dprint-plugin-markup": "0.27.0",
    "dprint-plugin-yaml": "0.6.0",
    "@dprint/typescript": "0.96.0",
    "@dprint/formatter": "~0.5.1",
    "jsonc-parser": "3.3.1"
  },
  "bundledDependencies": [],
  "devDependencies": {},
  "peerDependencies": {
    "eslint": "^10.3.0",
    "typescript": "~6.0.3"
  }
}
