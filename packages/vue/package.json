{
  "name": "@effect-app/vue",
  "version": "4.0.0-beta.279",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/effect-ts-app/libs/tree/main/packages/vue",
  "dependencies": {
    "@formatjs/intl": "^4.1.12",
    "@tanstack/vue-query": "5.96.2",
    "@vueuse/core": "^14.3.0",
    "change-case": "^5.4.4",
    "effect-app": "workspace:*",
    "query-string": "^9.4.0"
  },
  "peerDependencies": {
    "@effect/atom-vue": "^4.0.0-beta.84",
    "@effect/platform-browser": "^4.0.0-beta.84",
    "@sentry/browser": "^10.55.0",
    "effect": "^4.0.0-beta.84",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.84",
    "@formatjs/icu-messageformat-parser": "^3.5.10",
    "@types/node": "25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "intl-messageformat": "^11.2.7",
    "typescript": "~6.0.3",
    "vite": "^8.0.15",
    "vitest": "^4.1.7"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./internal/*": null,
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./internal/*": null,
      "./*": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      }
    },
    "directory": ".publish",
    "linkDirectory": false
  },
  "scripts": {
    "watch": "pnpm build:tsc -w",
    "build:tsc": "pnpm clean-dist && pnpm check && node ../../scripts/rewrite-dist-declaration-imports.mjs dist",
    "check": "tsgo --build",
    "build": "pnpm build:tsc",
    "watch2": "pnpm clean-dist && NODE_OPTIONS=--max-old-space-size=6144 tsgo -w",
    "clean": "rm -rf dist",
    "clean-dist": "sh ../../scripts/clean-dist.sh",
    "circular": "pnpm circular:src && pnpm circular:dist",
    "circular:src": "madge --circular --ts-config ./tsconfig.json --extensions ts ./src",
    "circular:dist": "madge --circular --extensions js ./dist",
    "compile": "NODE_OPTIONS=--max-old-space-size=6144 tsgo --noEmit",
    "lint": "oxlint --quiet --type-aware ./src && pnpm exec dprint check --config ../../dprint.jsonc .",
    "lint-fix": "oxlint --quiet --type-aware --fix ./src && pnpm exec dprint fmt --config ../../dprint.jsonc .",
    "test": "vitest",
    "test:run": "pnpm run test run --passWithNoTests",
    "testsuite": "pnpm lint && pnpm circular && pnpm run test:run",
    "ncu": "ncu",
    "pub": "pnpm publish --access public",
    "prepack": "node ../../scripts/stagePublishPackage.mjs prepack",
    "postpack": "node ../../scripts/stagePublishPackage.mjs postpack",
    "postpublish": "node ../../scripts/stagePublishPackage.mjs postpublish"
  },
  "gitHead": "bd8e27eea3eff97db8739d577d67e7336c078d28",
  "sideEffects": [
    "./dist/faker.js",
    "./faker",
    "./src/faker",
    "./dist/faker",
    "./dist/src/faker.js",
    "./dist/faker.js"
  ]
}
