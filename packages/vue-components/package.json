{
  "name": "@effect-app/vue-components",
  "version": "4.0.0-beta.128",
  "scripts": {
    "check": "vue-tsc",
    "build": "pnpm build:run",
    "build:run": "rimraf dist && vue-tsc && vite build && cp src/reset.css dist/reset.css",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint src stories .storybook",
    "ncu": "ncu",
    "clean": "rm -rf dist",
    "lint-fix": "pnpm lint --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch"
  },
  "peerDependencies": {
    "@mdi/js": "^7.4.47",
    "effect": "^4.0.0-beta.52",
    "intl-messageformat": "^11.2.1",
    "mdi-js": "^1.0.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.32",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@effect-app/eslint-shared-config": "workspace:*",
    "@storybook/vue3": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^14.2.1",
    "dprint": "^0.54.0",
    "jsdom": "^29.0.2",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "storybook": "^10.3.5",
    "storybook-vue3-router": "^7.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5",
    "vue-router": "^5.0.4",
    "vue-toastification": "^2.0.0-rc.5",
    "vue-tsc": "^3.2.7",
    "vuetify": "^4.0.5"
  },
  "files": [
    "src",
    "dist"
  ],
  "module": "./dist/vue-components.es.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/vue-components.es.js"
    },
    "./dist/vue-components.css": "./dist/vue-components.css",
    "./reset.css": {
      "development": "./src/reset.css",
      "default": "./dist/reset.css"
    }
  },
  "dependencies": {
    "@effect-app/vue": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@tanstack/vue-form": "^1.23.5",
    "effect-app": "workspace:*",
    "highlight.js": "^11.11.1",
    "mitt": "^3.0.1",
    "vue3-highlightjs": "^1.0.5"
  }
}
