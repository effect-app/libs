{
  "name": "@effect-app/eslint-codegen-model",
  "description": "Contains eslint helpers",
  "sideEffects": false,
  "type": "module",
  "version": "2.0.0-beta.27",
  "bin": {
    "effect-app-codegen": "./dist/cli.js"
  },
  "scripts": {
    "watch": "pnpm build:tsc -w",
    "build:tsc": "pnpm clean-dist && pnpm check",
    "check": "tsgo --build",
    "build": "tsgo",
    "codegen": "pnpm build && node ./dist/cli.js",
    "circular": "madge --circular --ts-config ./tsconfig.json --extensions ts ./src",
    "ncu": "ncu",
    "pub": "pnpm publish --access public",
    "prepack": "node ../../scripts/stagePublishPackage.mjs prepack",
    "postpack": "node ../../scripts/stagePublishPackage.mjs postpack",
    "postpublish": "node ../../scripts/stagePublishPackage.mjs postpublish"
  },
  "dependencies": {
    "glob": "^11.1.0",
    "js-yaml": "4.2.0",
    "oxc-parser": "0.133.0"
  },
  "peerDependencies": {
    "typescript": ">=5.5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "madge": "8.0.0",
    "oxlint": "1.67.0",
    "typescript": "~6.0.3",
    "effect-app": "workspace:*"
  },
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./oxlint": {
      "types": "./src/oxlint/index.ts",
      "default": "./src/oxlint/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./oxlint": {
        "types": "./dist/oxlint/index.d.ts",
        "default": "./dist/oxlint/index.js"
      }
    },
    "directory": ".publish",
    "linkDirectory": false
  },
  "author": "Wessel van der Veen & Scott vanBommel",
  "license": "ISC"
}
