{
  "name": "@effect-app/eslint-shared-config",
  "version": "0.5.7-beta.6",
  "description": "Shared flat ESLint base & vue configs for effect-app monorepo",
  "license": "MIT",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "watch": "pnpm build -w",
    "build": "echo 'Nothing to build (config only)'",
    "pub": "pnpm prepublish && npm publish --access public",
    "prepublish": "echo 'No build step for config package'",
    "postpublish": "echo 'Published @effect-app/eslint-shared-config'",
    "prepack": "echo 'ready'"
  },
  "exports": {
    "./eslint.base.config": {
      "default": "./src/eslint.base.config.mjs"
    },
    "./eslint.vue.config": {
      "default": "./src/eslint.vue.config.mjs"
    }
  },
  "dependencies": {
    "@effect-app/eslint-codegen-model": "workspace:*",
    "@eslint/js": "10.0.1",
    "@eslint/eslintrc": "3.3.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-codegen": "0.17.0",
    "eslint-plugin-sort-destructure-keys": "3.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "@ben_12/eslint-plugin-dprint": "1.17.0",
    "eslint-plugin-formatjs": "6.4.4",
    "@vue/eslint-config-typescript": "14.7.0",
    "typescript-eslint": "8.57.2",
    "eslint-plugin-vue": "10.8.0",
    "dprint-plugin-malva": "0.15.2",
    "dprint-plugin-markup": "0.27.0",
    "dprint-plugin-yaml": "0.6.0",
    "@dprint/typescript": "0.95.15",
    "@eslint/compat": "2.0.3",
    "eslint-import-resolver-webpack": "0.13.10",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-watch": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@dprint/formatter": "~0.4.1",
    "jsonc-parser": "3.3.1"
  },
  "bundledDependencies": [
    "@ben_12/eslint-plugin-dprint"
  ],
  "devDependencies": {},
  "peerDependencies": {
    "eslint": "^10.1.0",
    "typescript": "~6.0.2",
    "dprint": "^0.53.1"
  }
}
